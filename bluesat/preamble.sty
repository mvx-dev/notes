% NOTE: type keys are matched case-sensitively — pass lowercase, e.g.
% \begin{callout}{info}

\newcommand{\setcallouttitlefromtype}[1]{%
    \IfStrEqCase{#1}{%
        {note}{\def\callouttitle{Note}}%
        {info}{\def\callouttitle{Info}}%
        {todo}{\def\callouttitle{Todo}}%
        {tip}{\def\callouttitle{Tip}}%
        {hint}{\def\callouttitle{Hint}}%
        {important}{\def\callouttitle{Important}}%
        {success}{\def\callouttitle{Success}}%
        {check}{\def\callouttitle{Check}}%
        {done}{\def\callouttitle{Done}}%
        {question}{\def\callouttitle{Question}}%
        {help}{\def\callouttitle{Help}}%
        {faq}{\def\callouttitle{FAQ}}%
        {warning}{\def\callouttitle{Warning}}%
        {caution}{\def\callouttitle{Caution}}%
        {attention}{\def\callouttitle{Attention}}%
        {failure}{\def\callouttitle{Failure}}%
        {fail}{\def\callouttitle{Fail}}%
        {missing}{\def\callouttitle{Missing}}%
        {danger}{\def\callouttitle{Danger}}%
        {error}{\def\callouttitle{Error}}%
        {bug}{\def\callouttitle{Bug}}%
        {example}{\def\callouttitle{Example}}%
        {quote}{\def\callouttitle{Quote}}%
        {cite}{\def\callouttitle{Quote}}%
    }[\edef\callouttitle{\MakeUppercase{#1}}]%
}

\newcommand{\setcalloutaccent}[1]{%
  \IfStrEqCase{#1}{%
    {note}{\def\calloutaccent{ctpBlue}}%
    {info}{\def\calloutaccent{ctpSky}}%
    {todo}{\def\calloutaccent{ctpLavender}}%
    {tip}{\def\calloutaccent{ctpTeal}}%
    {hint}{\def\calloutaccent{ctpTeal}}%
    {important}{\def\calloutaccent{ctpMauve}}%
    {success}{\def\calloutaccent{ctpGreen}}%
    {check}{\def\calloutaccent{ctpGreen}}%
    {done}{\def\calloutaccent{ctpGreen}}%
    {question}{\def\calloutaccent{ctpYellow}}%
    {help}{\def\calloutaccent{ctpYellow}}%
    {faq}{\def\calloutaccent{ctpYellow}}%
    {warning}{\def\calloutaccent{ctpPeach}}%
    {caution}{\def\calloutaccent{ctpPeach}}%
    {attention}{\def\calloutaccent{ctpPeach}}%
    {failure}{\def\calloutaccent{ctpRed}}%
    {fail}{\def\calloutaccent{ctpRed}}%
    {missing}{\def\calloutaccent{ctpRed}}%
    {danger}{\def\calloutaccent{ctpRed}}%
    {error}{\def\calloutaccent{ctpRed}}%
    {bug}{\def\calloutaccent{ctpMaroon}}%
    {example}{\def\calloutaccent{ctpMauve}}%
    {quote}{\def\calloutaccent{ctpOverlay0}}%
    {cite}{\def\calloutaccent{ctpOverlay0}}%
  }[\def\calloutaccent{ctpBlue}]%
}

\NewDocumentEnvironment{callout}{m o}
{%
  \def\callouttype{#1}%
  \setcalloutaccent{#1}%
  \IfNoValueTF{#2}
    {\setcallouttitlefromtype{#1}}
    {\def\callouttitle{#2}}%
  \begin{tcolorbox}[
    breakable,
    sharp corners,
    skin=enhancedmiddle jigsaw,
    parbox=false,
    boxrule=0mm,
    leftrule=2mm,
    boxsep=0mm,
    arc=0mm,
    outer arc=0mm,
    attach title to upper,
    after title={.\ },
    coltitle=black,
    colback=\calloutaccent!10,
    colframe=\calloutaccent,
    title={\callouttitle},
    fonttitle=\bfseries
  ]
}
{%
  \end{tcolorbox}
}

